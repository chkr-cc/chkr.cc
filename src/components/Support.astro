                    <h2 class="title">Need Help?</h2>
                </div>
            </div>
        </div>
        <div class="row mt--30 justify-content-center">
            <div class="col-lg-2 col-md-3 col-6 mt--30">
                <a
                    href="https://t.me/chkrcc_bot"
                    target="_blank"
                    class="rn-btn w-100 text-center"
                >
                    <span><i data-feather="send" class="mr-2"></i>Contact</span>
