---
// src/components/Features.astro
---

<!-- Start Features Area -->
<div class="rn-service-area rn-section-gap section-separator" id="features">
    <div class="container">
        <div class="row">
            <div class="col-lg-12">
                <div class="section-title text-left">
                    <span class="subtitle">Features</span>
                    <h2 class="title">How it Works?</h2>
                </div>
            </div>
        </div>
        <div class="row row--25 mt_md--10 mt_sm--10">
            <!-- Start Single Features -->
            <div
                class="col-lg-6 col-xl-4 col-md-6 col-sm-12 col-12 mt--50 mt_md--30 mt_sm--30"
            >
                <div class="rn-service">
                    <div class="inner">
                        <div class="icon">
                            <i data-feather="calendar"></i>
                        </div>
                        <div class="content">
                            <h4 class="title">Date Check</h4>
                            <p class="description">
                                Compare the credit card expired date with today
                                to see the card expired or not.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
            <!-- Start Single Service -->
            <div
                class="col-lg-6 col-xl-4 col-md-6 col-sm-12 col-12 mt--50 mt_md--30 mt_sm--30"
            >
                <div class="rn-service">
                    <div class="inner">
                        <div class="icon">
                            <i data-feather="credit-card"></i>
                        </div>
                        <div class="content">
                            <h4 class="title">Number Check</h4>
                            <p class="description">
                                A Luhn Algorithm checker tool will check your
                                card number against the Luhn Algorithm for
                                validating.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
            <!-- Start Single Service -->
            <div
                class="col-lg-6 col-xl-4 col-md-6 col-sm-12 col-12 mt--50 mt_md--30 mt_sm--30"
            >
                <div class="rn-service">
                    <div class="inner">
                        <div class="icon">
                            <i data-feather="hash"></i>
                        </div>
                        <div class="content">
                            <h4 class="title">BIN/IIN Check</h4>
                            <p class="description">
                                We will look up your card bin in our database
                                which contains more than 300,000 bin records
                            </p>
                        </div>
                    </div>
                </div>
            </div>
            <!-- Start Single Service -->
            <div
                class="col-lg-6 col-xl-4 col-md-6 col-sm-12 col-12 mt--50 mt_md--30 mt_sm--30"
            >
                <div class="rn-service">
                    <div class="inner">
                        <div class="icon">
                            <i data-feather="shield"></i>
                        </div>
                        <div class="content">
                            <h4 class="title">Security Check</h4>
                            <p class="description">
                                Verify CVV and other security features to ensure
                                the card meets standard security requirements.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
            <!-- Start Single Service -->
            <div
                class="col-lg-6 col-xl-4 col-md-6 col-sm-12 col-12 mt--50 mt_md--30 mt_sm--30"
            >
                <div class="rn-service">
                    <div class="inner">
                        <div class="icon">
                            <i data-feather="globe"></i>
                        </div>
                        <div class="content">
                            <h4 class="title">Geographic Info</h4>
                            <p class="description">
                                Provide detailed information about the card's
                                issuing country, including currency and location
                                data.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
            <!-- Start Single Service -->
            <div
                class="col-lg-6 col-xl-4 col-md-6 col-sm-12 col-12 mt--50 mt_md--30 mt_sm--30"
            >
                <div class="rn-service">
                    <div class="inner">
                        <div class="icon">
                            <i data-feather="database"></i>
                        </div>
                        <div class="content">
                            <h4 class="title">Bank Details</h4>
                            <p class="description">
                                Retrieve comprehensive information about the
                                issuing bank and card brand specifications.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
