---
// src/components/AiSection.astro
---

<!-- Start AI Section -->
<div class="rn-service-area rn-section-gap section-separator" id="ai">
    <div class="container">
        <div class="row">
            <div class="col-lg-12">
                <div
                    class="section-title text-left"
                    data-aos="fade-up"
                    data-aos-duration="500"
                    data-aos-delay="100"
                    data-aos-once="true"
                >
                    <span class="subtitle">Ecosystem</span>
                    <h2 class="title">AI Capabilities</h2>
                </div>
            </div>
        </div>

        <div class="row mt--40 justify-content-center">
            <div class="col-lg-8">
                <div
                    class="rn-service text-center"
                    data-aos="fade-up"
                    data-aos-duration="500"
                    data-aos-delay="200"
                    data-aos-once="true"
                >
                    <div
                        class="inner p-5"
                        style="border-radius: 12px; background: linear-gradient(145deg, #1e2024, #23272b); box-shadow: 10px 10px 19px #1c1e22, -10px -10px 19px #262a2e; border: 1px solid rgba(255, 255, 255, 0.05); position: relative; overflow: hidden;"
                    >
                        <!-- Decorative background glow -->
                        <div
                            style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); width: 200px; height: 200px; background: rgba(32, 178, 124, 0.1); filter: blur(60px); border-radius: 50%; pointer-events: none;"
                        >
                        </div>

                        <div
                            class="icon mb-4 d-flex justify-content-center position-relative"
                        >
                            <div
                                class="d-inline-block p-4 rounded-circle"
                                style="background: rgba(32, 178, 124, 0.1); border: 1px solid rgba(32, 178, 124, 0.2);"
                            >
                                <i
                                    data-feather="cpu"
                                    class="text-primary"
                                    style="width: 48px; height: 48px;"></i>
                            </div>
                        </div>

                        <h3
                            class="title text-white mb-3"
                            style="font-size: 28px;"
                        >
                            AI Validation Agent & MCP
                        </h3>

                        <p
                            class="description fs-5 mb-5 mx-auto text-light opacity-75"
                            style="max-width: 600px; line-height: 1.6;"
                        >
                            Our intelligent validation agent and Model Context
                            Protocol (MCP) server are currently in the workshop.
                            Soon, you will be able to integrate CHKR.CC directly
                            into your advanced AI workflows.
                        </p>

                        <div class="mt-2 text-center position-relative">
                            <span
                                class="badge px-4 py-2 text-uppercase fw-bold rounded-pill"
                                style="font-size: 14px; letter-spacing: 2px; background: rgba(32, 178, 124, 0.1); color: #20b27c; border: 1px solid rgba(32, 178, 124, 0.3);"
                            >
                                Coming Soon
                            </span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
