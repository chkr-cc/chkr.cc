---
// src/components/Changelog.astro
---

<!-- Start Changelog Area -->
<div id="changelog" class="rn-resume-area rn-section-gap section-separator">
    <div class="container">
        <div class="row">
            <div class="col-lg-12">
                <div class="section-title text-center">
                    <span class="subtitle">History</span>
                    <h2 class="title">Changelog</h2>
                </div>
            </div>
        </div>
        <div class="row mt--40">
            <div class="col-lg-8 offset-lg-2">
                <div class="personal-experience-inner">
                    <div class="experience-list">
                        <!-- Start Single List  -->
                        <div class="resume-single-list">
                            <div class="inner">
                                <div class="heading">
                                    <div class="title">
                                        <h4>v2.0.0</h4>
                                        <time datetime="2026-03-01"
                                            >2026-03-01</time
                                        >
                                    </div>
                                </div>
                                <p class="description">
                                    - Modernized frontend stack to Astro.<br />
                                    - Prepared internal logic for AI Tool/MCP integrations.<br
                                    />
                                    - Performance improvements (Zero jQuery, Lighthouse
                                    optimization).
                                </p>
                            </div>
                        </div>
                        <!-- End Single List  -->
                        <!-- Start Single List  -->
                        <div class="resume-single-list">
                            <div class="inner">
                                <div class="heading">
                                    <div class="title">
                                        <h4>v1.3.3</h4>
                                        <time datetime="2025-12-31"
                                            >2025-12-31</time
                                        >
                                    </div>
                                </div>
                                <p class="description">
                                    - Optimized the BIN checking API.<br />
                                    - minor bug fixes.
                                </p>
                            </div>
                        </div>
                        <!-- End Single List  -->
                        <!-- Start Single List  -->
                        <div class="resume-single-list">
                            <div class="inner">
                                <div class="heading">
                                    <div class="title">
                                        <h4>v1.3.0</h4>
                                        <time datetime="2025-06-24"
                                            >2025-06-24</time
                                        >
                                    </div>
                                </div>
                                <p class="description">
                                    - MM|YY format now supported by both web app
                                    and API.<br />
                                    - Update API documentation.<br />
                                    - Update support system.<br />
                                    - BIN database update.<br />
                                    - Fixed a bug in the geographic location data.
                                </p>
                            </div>
                        </div>
                        <!-- End Single List  -->
                        <!-- Start Single List  -->
                        <div class="resume-single-list">
                            <div class="inner">
                                <div class="heading">
                                    <div class="title">
                                        <h4>v1.2.0</h4>
                                        <time datetime="2024-05-09"
                                            >2024-05-09</time
                                        >
                                    </div>
                                </div>
                                <p class="description">
                                    - Gateway update.<br />
                                    - API support.<br />
                                    - minor bug fixes.
                                </p>
                            </div>
                        </div>
                        <!-- End Single List  -->
                        <!-- Start Single List  -->
                        <div class="resume-single-list">
                            <div class="inner">
                                <div class="heading">
                                    <div class="title">
                                        <h4>v1.1.0</h4>
                                        <time datetime="2022-07-29"
                                            >2022-07-29</time
                                        >
                                    </div>
                                </div>
                                <p class="description">
                                    - BIN Generator<br />
                                    - BIN database update.<br />
                                    - Bug fixes.
                                </p>
                            </div>
                        </div>
                        <!-- End Single List  -->
                        <!-- Start Single List  -->
                        <div class="resume-single-list">
                            <div class="inner">
                                <div class="heading">
                                    <div class="title">
                                        <h4>v1.0.0</h4>
                                        <time datetime="2022-04-29"
                                            >2022-04-29</time
                                        >
                                    </div>
                                </div>
                                <p class="description">
                                    - Initial Launch.<br />
                                    - Launched web app.<br />
                                    - Supported basic credit card validation.<br
                                    />
                                </p>
                            </div>
                        </div>
                        <!-- End Single List  -->
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
